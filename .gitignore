# =========================
# Project database rules
# =========================
# Keep the main SQLite database tracked:
# data/rectg.db

# Ignore SQLite temporary runtime files
data/*.db-journal
data/*.db-wal
data/*.db-shm
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Ignore desktop control center runtime state
data/control_center.json
data/control_center.lock

# Ignore data backups / temporary exports
data/*.bak
data/*.backup
data/*.tmp
data/*.temp
data/*.log
web/public/data.json.tmp
web/public/sitemap.xml.tmp
web/public/robots.txt.tmp

# Ignore crawler raw dumps if generated later
data/raw/
data/cache/
data/tmp/
data/backups/

