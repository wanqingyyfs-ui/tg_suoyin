---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import AdBlock from '../components/AdBlock.astro';
import { buildDirectoryData } from '../utils/data';

const { categories, validSections, allItems, featuredItems, totalItems, typeStats, ads } = buildDirectoryData();
const initialSection = {
  id: 'featured',
  icon: '★',
  name: '精选推荐',
  fullName: '精选推荐',
  items: featuredItems,
};
const homeTopAds = ads.positions.home_top || [];
const homeBelowHeroAds = ads.positions.home_below_hero || [];
const directoryPayload = JSON.stringify({
  sections: [
    initialSection,
    ...validSections.map((group) => ({
      id: group.meta.id,
      icon: group.meta.icon,
      name: group.meta.name,
      fullName: group.meta.fullName,
      keywords: group.meta.keywords || '',
      items: group.items,
    })),
  ],
  allItems,
  ads,
}).replace(/</g, '\\u003c');

const pageDescription = `收录 ${totalItems} 个 Telegram 中文频道与群组，支持分类浏览、关键词搜索、详情页和直达链接。`;
---

<Layout description={pageDescription}>
  <div id="app">
    <!-- 侧边栏 -->
    <aside id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 2L11 13"></path>
            <path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
          </svg>
          <div>
            <div class="sidebar-title">rectg</div>
            <div class="sidebar-subtitle">Telegram 索引</div>
          </div>
        </div>
        <button id="close-sidebar-btn" aria-label="关闭侧边栏">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav id="category-nav">
        <div class="nav-section-label">分类</div>
        <div class="nav-item active" data-id="featured">
            <span class="nav-icon">★</span>
            <span>精选推荐</span>
        </div>
        {categories.map(cat => (
          <div class="nav-item" data-id={cat.id}>
              <span class="nav-icon">{cat.icon}</span>
              <span>{cat.name}</span>
          </div>
        ))}
      </nav>
      <div class="sidebar-footer">
        <a href="https://github.com/wanqingyyfs-ui/rectg/issues/new" target="_blank" rel="noopener" class="submit-btn" title="提交新的频道或群组">
          提交收录
        </a>
      </div>
    </aside>

    <!-- 移动端侧边栏遮罩 -->
    <div id="sidebar-overlay"></div>

    <!-- 主内容区 -->
    <main>
      <header>
        <div class="header-left">
          <button id="menu-btn" aria-label="菜单">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
          <!-- 移动端显示的标题 -->
          <h2 class="mobile-title">rectg</h2>
        </div>

        <div class="header-right">
          <a class="topbar-link" href="https://github.com/wanqingyyfs-ui/rectg" target="_blank" rel="noopener">GitHub</a>
          <button id="theme-toggle" aria-label="切换主题">
            <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>
        </div>
      </header>

      <!-- Reading Progress Bar -->
      <div id="progress-container">
        <div id="progress-bar"></div>
      </div>

      <section class="tool-hero">
        <div class="tool-hero-main">
          <p class="eyebrow">Telegram Resource Index</p>
          <h1 class="hero-title">Telegram 中文资源索引</h1>
          <p class="hero-subtitle">按主题浏览频道和群组，搜索时自动切换为全站结果。</p>
        </div>
        <div class="hero-stats" aria-label="收录统计">
          <div class="hero-stat">
            <span class="hero-stat-label">总收录</span>
            <strong class="hero-stat-value">{totalItems}</strong>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-label">分类</span>
            <strong class="hero-stat-value">{validSections.length}</strong>
          </div>
          {typeStats.map(stat => (
            <div class="hero-stat">
              <span class="hero-stat-label">{stat.name}</span>
              <strong class="hero-stat-value">{stat.count}</strong>
            </div>
          ))}
        </div>
        <div class="search-box">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-input" placeholder="搜索频道、群组、关键词或 t.me 地址" autocomplete="off" />
        </div>
      </section>

      {homeTopAds.length > 0 && (
        <div class="ad-strip">
          {homeTopAds.slice(0, 2).map(ad => <AdBlock ad={ad} />)}
        </div>
      )}

      <div class="bulletin" id="bulletin">
        <span class="bulletin-icon">i</span>
        <div class="bulletin-text-container">
          <span id="bulletin-text">本站数据来自 SQLite 维护源，当前已收录 {totalItems} 个公开 Telegram 资源。</span>
        </div>
      </div>

      {homeBelowHeroAds.length > 0 && (
        <div class="ad-strip ad-strip-secondary">
          {homeBelowHeroAds.slice(0, 2).map(ad => <AdBlock ad={ad} compact />)}
        </div>
      )}

      <div id="content-container">
        <section class="category-section" id="active-section" data-current-id={initialSection.id}>
          <h3 class="category-title">
            <span id="active-section-title">{initialSection.fullName}</span>
            <span id="active-section-meta" class="category-title-meta">({initialSection.items.length})</span>
          </h3>
          <div class="grid" id="active-grid">
            {initialSection.items.map(item => (
              <Card
                id={item.id}
                title={item.title}
                desc={item.desc}
                url={item.url}
                typeName={item.typeName}
                countStr={item.countStr}
                category="精选推荐"
              />
            ))}
          </div>
        </section>

        <div id="empty-state" class="empty-state" style="display: none;">
            <h3>未找到匹配的结果</h3>
            <p>尝试搜索其他关键词</p>
        </div>
      </div>
    </main>
  </div>

  <!-- Back to Top Button -->
  <button id="back-to-top" class="back-to-top" aria-label="返回顶部">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="19" x2="12" y2="5"></line>
      <polyline points="5 12 12 5 19 12"></polyline>
    </svg>
  </button>
  
  <div id="toast" class="toast">已复制链接</div>

  <footer class="site-footer">
    <div class="footer-content">
      <p>⚠️ <strong>免责声明</strong>：本网站仅供技术学习与信息导航使用。严禁中国大陆地区用户使用，所有使用者须严格遵守所在地区法律法规，一切因违规使用产生的法律责任均与本网站无关。</p>
      <p class="footer-copyright">© 2026 rectg – Telegram 精选导航</p>
    </div>
  </footer>

  <script id="directory-data" type="application/json" set:html={directoryPayload}></script>
  <script src="../scripts/main.js"></script>
</Layout>
