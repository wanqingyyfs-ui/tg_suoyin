# TG 索引环境变量示例
# 复制此文件为 .env 后按需修改，也可以在桌面控制中心“设置”页面维护。

# 站点域名。
# 不设置时，脚本默认使用 https://tg-suoyin.vercel.app。
SITE_URL=https://tg-suoyin.vercel.app

# Telegram Bot Token。
# 从 Telegram 的 @BotFather 获取。
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Bot 请求配置。
BOT_REQUEST_TIMEOUT=30
BOT_POLLING_TIMEOUT=25

# Bot Webhook 配置。
# 本地测试可使用 polling；生产环境建议使用 HTTPS Webhook。
BOT_WEBHOOK_HOST=127.0.0.1
BOT_WEBHOOK_PORT=8899
BOT_WEBHOOK_SECRET=change_this_secret

# 本地管理后台配置。
# ADMIN_TOKEN 留空表示不启用访问 Token；设置后访问后台要带 ?token=你的Token。
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8787
ADMIN_TOKEN=

# 桌面控制中心内置前端服务配置。
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=4321

# 当前项目的主数据源是 SQLite：data/rectg.db。
# README 不再作为主数据源。
# 前端静态数据由 scripts/export_frontend_data.py 生成。
